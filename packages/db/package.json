{
  "name": "@forward/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/drizzle && cp -R drizzle dist/drizzle",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@forward/shared": "workspace:*",
    "drizzle-kit": "1.0.0-beta.23",
    "drizzle-orm": "1.0.0-beta.22"
  }
}
